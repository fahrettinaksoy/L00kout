{
  "name": "L00kout",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prepare": "husky || true",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "docs": "typedoc",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "ci": "npm run lint && npm run format:check && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@mdi/js": "^7.4.47",
    "@nuxtjs/i18n": "^10.3.0",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/node": "^8.47.0",
    "@sentry/vue": "^8.47.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "cheerio": "^1.2.0",
    "consola": "^3.4.0",
    "node-fetch": "^3.3.2",
    "nuxt": "^4.4.4",
    "nuxt-security": "^2.6.0",
    "pinia": "^3.0.4",
    "prom-client": "^15.1.3",
    "psl": "^1.15.0",
    "sass": "^1.99.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6",
    "vuetify": "^3.12.6",
    "vuetify-nuxt-module": "^1.0.0-beta",
    "whoiser": "^2.0.0-beta.10",
    "xml2js": "^0.6.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@nuxt/eslint": "^0.7.0",
    "@playwright/test": "^1.58.2",
    "@size-limit/preset-app": "^12.1.0",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^22.10.0",
    "@types/psl": "^1.1.3",
    "@vitest/coverage-v8": "^2.1.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.32.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.0",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.0",
    "size-limit": "^12.1.0",
    "typedoc": "^0.28.19",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.1.0"
  },
  "lint-staged": {
    "*.{ts,vue,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,scss,yml,yaml}": [
      "prettier --write"
    ]
  }
}
