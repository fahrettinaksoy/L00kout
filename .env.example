# ──────────────────────────────────────────────────────────────────────
# L00kout — Optional API keys for richer check results
# Copy this file to `.env` and fill values. All are OPTIONAL — checks
# fall back gracefully when keys are missing.
# ──────────────────────────────────────────────────────────────────────

# Google PageSpeed Insights (Lighthouse) — FREE
# Without key: ~25 req/day per IP (rate limited).
# Get key: https://developers.google.com/speed/docs/insights/v5/get-started
# Enable PageSpeed Insights API at: https://console.cloud.google.com/apis/library
PAGESPEED_API_KEY=

# Shodan — FREE tier available
# Provides exposed services, ports and CVE data for IPs.
# Register: https://account.shodan.io/register
SHODAN_API_KEY=

# Google Safe Browsing — FREE
# Detects malware/phishing/unwanted-software URLs.
# 1) Create project: https://console.cloud.google.com/projectcreate
# 2) Enable: https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
# 3) Credentials → API Key
GOOGLE_SAFE_BROWSING_KEY=

# ScreenshotOne — production-quality screenshots
# Free tier: 100 screenshots/month. Without key uses thum.io fallback.
# Register: https://screenshotone.com/
SCREENSHOT_API_KEY=

# ──────────────────────────────────────────────────────────────────────
# Operations
# ──────────────────────────────────────────────────────────────────────

# Sentry DSN — leave blank to disable error reporting.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# CORS origin for /api/checks/** (production: set to your own origin).
API_CORS_ORIGIN=*

# Per-IP rate limiting on /api/checks/**.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Client batching / timeouts (exposed to public runtimeConfig).
NUXT_PUBLIC_API_TIMEOUT_MS=40000
NUXT_PUBLIC_REQUEST_BATCH_SIZE=5
